         />

         <div className="grid gap-4 xl:grid-cols-2">
           <DistributionBars
             title="ヒッティング時の得点分布"
             data={result.noBuntDist}
           />
           <DistributionBars
             title="バント時の得点分布"
             data={result.buntDist}
           />
         </div>
       </>
     ) : (
       <Card className="rounded-2xl shadow-sm">
         <CardContent className="p-6 text-sm text-slate-600">
           まだ解析結果がありません
         </CardContent>
       </Card>
     )}
   </>
 );